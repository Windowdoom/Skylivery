NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side (for /api/quote geocoding)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_SERVER_KEY

# Client-side (for address autocomplete). Can be the same key
# as GOOGLE_MAPS_API_KEY if restricted with HTTP referrers in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_BROWSER_KEY
