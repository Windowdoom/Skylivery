NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Server-only (bypasses RLS for the /admin dashboard)
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_OR_SERVICE_ROLE_KEY

# Server-side (for /api/quote geocoding)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_SERVER_KEY

# Client-side (for address autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_BROWSER_KEY

# Admin dashboard login (any strong string you pick)
ADMIN_PASSWORD=change-me-to-something-long

# Push notification on new booking (optional).
# Sign up a free topic at ntfy.sh (e.g. skylivery-bookings-fk39qz), install the
# ntfy app on your phone, subscribe to the topic. Then paste the URL below.
NTFY_URL=https://ntfy.sh/YOUR-PRIVATE-TOPIC
